{
  "data": {
    "events_path": "data/mimic-demo/events/data_0.parquet",
    "icu_stay_path": "data/mimic-demo/icu_stay/data_0.parquet",
    "output_dir": "oracle_results",
    "max_patients": null
  },
  "data_loading": {
    "agent_observation_hours": 12,
    "oracle_observation_hours": null
  },
  "oracle_time_windows": {
    "current_window_hours": 1,
    "window_step_hours": 2,
    "include_pre_icu_data": true,
    "use_discharge_summary_for_history": true,
    "num_discharge_summaries": 2,
    "relative_report_codes": [
      "NOTE_RADIOLOGYREPORT",
      "NOTE_DISCHARGESUMMARY"
    ],
    "pre_icu_history_hours": 48
  },
  "oracle_context": {
    "history_hours": 1,
    "future_hours": 3,
    "use_discharge_summary": true,
    "include_icu_outcome_in_prompt": true,
    "top_k_recommendations": 3
  },
  "agent_time_windows": {
    "current_window_hours": 0.5,
    "window_step_hours": 0.5,
    "include_pre_icu_data": true,
    "use_discharge_summary_for_history": false,
    "num_discharge_summaries": 3
  },
  "llm": {
    "provider": "openai",
    "model": "gpt-5-mini",
    "temperature": 1.0,
    "max_tokens": 128000
  },
  "remem": {
    "max_state_length": 1500,
    "enable_intra_patient_refinement": true
  },
  "agent_fold": {
    "enable_key_events_extraction": true,
    "max_trajectory_entries": 20
  },
  "agent_multi": {
    "use_observer_agent": false,
    "use_memory_agent": false,
    "use_reflection_agent": false,
    "observer_use_thinking": false,
    "memory_use_thinking": false,
    "reflection_use_thinking": false,
    "predictor_use_thinking": true,
    "observer_cache": {
      "enabled": true,
      "cache_dir": "experiment_results/observer_cache"
    }
  },
  "med_agent": {
    "use_llm_static_compression": true,
    "baseline_lab_lookback_start_hours": 72,
    "baseline_lab_lookback_end_hours": 24,
    "max_active_problems": 8,
    "max_critical_events": 20,
    "max_patterns": 8,
    "memory_use_thinking": false,
    "predictor_use_thinking": true
  },
  "oracle_logging": {
    "log_dir": "logs/oracle",
    "save_trajectories": true
  },
  "agent_logging": {
    "log_dir": "logs/agent",
    "save_trajectories": true
  }
}
