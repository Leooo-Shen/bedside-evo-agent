{
  "data": {
    "events_path": "data/mimic-demo/events",
    "icu_stay_path": "data/mimic-demo/icu_stay",
    "output_dir": "oracle_results",
    "max_patients": null
  },
  "data_loading": {
    "agent_observation_hours": null,
    "oracle_observation_hours": null
  },
  "oracle_time_windows": {
    "current_window_hours": 0.5,
    "window_step_hours":2,
    "include_pre_icu_data": true,
    "use_discharge_summary_for_history": true,
    "num_discharge_summaries": 2,
    "pre_icu_history_hours": 48
  },
  "oracle_context": {
    "history_hours": 1,
    "future_hours": 1,
    "use_discharge_summary": true,
    "compress_pre_icu_history": true,
    "include_icu_outcome_in_prompt": true,
    "top_k_recommendations": 5
  },
  "agent_time_windows": {
    "current_window_hours": 0.5,
    "window_step_hours": 0.5,
    "include_pre_icu_data": true,
    "use_discharge_summary_for_history": true,
    "num_discharge_summaries": 2,
    "pre_icu_history_hours": 48
  },
  "llm": {
    "provider": "google",
    "model": "qwen/qwen3-235b-a22b-instruct-2507-maas",
    "temperature": 0,
    "max_tokens": 4096
  },
  "remem": {
    "max_state_length": 1500,
    "enable_intra_patient_refinement": true
  },
  "agent_fold": {
    "enable_key_events_extraction": true,
    "max_trajectory_entries": 20
  },
  "agent_multi": {
    "use_observer_agent": false,
    "use_memory_agent": false,
    "use_reflection_agent": false,
    "observer_cache": {
      "enabled": true,
      "cache_dir": "experiment_results/observer_cache"
    }
  },
  "med_evo": {
    "max_working_windows": 3,
    "max_insights": 10,
    "max_trajectory_entries": 96,
    "episode_block_windows": 4,
    "insight_block_windows": 8,
    "observation_config_path": "config/med_evo_rule_event_detector.json"
  },
  "oracle_logging": {
    "log_dir": "logs/oracle",
    "save_trajectories": true
  },
  "agent_logging": {
    "log_dir": "logs/agent",
    "save_trajectories": true
  }
}
